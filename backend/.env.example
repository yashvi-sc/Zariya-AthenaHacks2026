# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real keys.

# --- Required for TTS (tips, interview voice) ---
ELEVENLABS_API_KEY=

# --- Required for Interview mode (Gemini) ---
# Use either name (GEMINI_API_KEY is checked first in code)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional: model id (default in code: gemini-2.5-flash). Older names like gemini-1.5-flash may 404.
# GEMINI_MODEL=gemini-2.5-pro

# --- Optional ElevenLabs tuning ---
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_VOICE_ID_SOFT=
# ELEVENLABS_VOICE_ID_AGGRESSIVE=
# ELEVENLABS_STABILITY_SOFT=0.62
# ELEVENLABS_SIMILARITY_SOFT=0.82
# ELEVENLABS_STABILITY_AGGRESSIVE=0.38
# ELEVENLABS_SIMILARITY_AGGRESSIVE=0.68

# --- Flask / auth (change in production) ---
# FLASK_SECRET_KEY=

# --- Email reports (optional) ---
# SENDER_EMAIL=
# EMAIL_PASSWORD=
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
